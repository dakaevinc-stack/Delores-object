# Публичный URL веб-панели приёмки (Streamlit: streamlit run admin_dashboard.py в репозитории bot-for-ameda).
# Пример: http://localhost:8501 или https://dashboard.example.com
VITE_AMEDA_INSPECTION_DASHBOARD_URL=http://94.242.58.24:8501/
#
# На сервере в shell: префикс VAR=value действует только на ОДНУ команду.
# Неверно:  VAR=... npm ci && npm run build   (vite не увидит VAR)
# Верно:    export VAR=... && npm ci && npm run build

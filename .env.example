# Скопируйте файл как .env и подправьте значения. Используется Vite на этапе сборки.
# На сервере удобнее задавать те же переменные через окружение перед `npm run build`
# (см. scripts/deploy/server-bootstrap.sh) — рекомендуем НЕ хранить production-секреты в .env.

# Публичный URL веб-панели приёмки (Streamlit: streamlit run admin_dashboard.py в репозитории bot-for-ameda).
# Пример: http://localhost:8501 или https://dashboard.example.com
VITE_AMEDA_INSPECTION_DASHBOARD_URL=http://94.242.58.24:8501/

# Заявки снабженцу и отчёты бригадира (server/site-forms.mjs).
# - Локально: запустите `npm run dev:site-forms-api` (он слушает :8787) и оставьте
#   VITE_SITE_FORMS_API_BASE пустым — Vite проксирует /api на :8787.
# - На production: оставьте пустым, если nginx раздаёт фронт и сам проксирует /api/* на бэкенд
#   (см. scripts/deploy/nginx-site-ip.conf.example). Указывайте полный URL только если
#   API живёт на другом домене/порте, чем фронт (тогда настройте CORS).
# VITE_SITE_FORMS_API_BASE=

# Секрет защиты записи. Если на сервере задан DELORESH_SITE_FORMS_WRITE_SECRET (см.
# scripts/deploy/site-forms.env.example) — укажите ровно тот же секрет здесь, иначе
# фронт не сможет создавать заявки/отчёты/загружать медиа.
# VITE_SITE_FORMS_WRITE_SECRET=

# На сервере в shell: префикс VAR=value действует только на ОДНУ команду.
# Неверно:  VAR=... npm ci && npm run build   (vite не увидит VAR во второй команде)
# Верно:    export VAR=... && npm ci && npm run build

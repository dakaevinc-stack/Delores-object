# Скопируйте на сервер как /etc/deloresh/site-forms.env (chmod 600).
# Файл читает systemd-сервис site-forms (см. site-forms.service).

# Порт, на котором слушает Node.js API. nginx будет проксировать /api/* сюда.
DELORESH_SITE_FORMS_PORT=8787

# Каталог, куда складываются JSON и медиафайлы. Должен принадлежать тому же
# пользователю, под которым работает сервис (см. User= в site-forms.service).
DELORESH_SITE_FORMS_DATA=/var/lib/deloresh/site-forms

# Секрет для записи. Если задан — фронту нужен тот же секрет в
# VITE_SITE_FORMS_WRITE_SECRET (передаётся как заголовок X-Deloresh-Write-Secret).
# Сгенерировать: openssl rand -hex 24
DELORESH_SITE_FORMS_WRITE_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ

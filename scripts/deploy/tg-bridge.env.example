# Скопируйте на сервер как /etc/deloresh/tg-bridge.env (chmod 600).
# Если файла нет — bootstrap автоматически НЕ поднимает tg-bridge.service.

# Токен от @BotFather. Получение:
#   1. В Telegram открыть @BotFather, /newbot, придумать имя и юзернейм.
#   2. Ответом придёт токен вида 1234567890:AA…
#   3. ВАЖНО: отключить privacy mode боту, чтобы он видел все
#      сообщения в группе:
#         /mybots → выбрать бота → Bot Settings → Group Privacy → Turn off
TG_BOT_TOKEN=ЗАМЕНИТЕ_НА_ТОКЕН

# (Опционально) ID групп, ОТКУДА слушаем отчёты. Несколько — через запятую.
# Если оставить пустым — бридж принимает отчёты из любого чата, в который
# его добавили. Получение chat_id:
#   1. Добавьте бота в группу (как админа, чтобы он точно видел сообщения).
#   2. Напишите туда любое сообщение.
#   3. На сервере выполните:
#        curl -s "https://api.telegram.org/bot$TG_BOT_TOKEN/getUpdates" | jq
#      В ответе у объекта chat будет id (отрицательное число вида -1001234567890).
TG_ALLOWED_CHAT_ID=

# URL site-forms API (бэкенд заявок/отчётов). Если бридж и API живут на одной
# машине — оставьте http://127.0.0.1:8787 (по умолчанию).
SITE_FORMS_API_BASE=http://127.0.0.1:8787

# Секрет для записи в site-forms. Должен совпадать с
# DELORESH_SITE_FORMS_WRITE_SECRET в /etc/deloresh/site-forms.env —
# bootstrap-скрипт автоматически копирует значение.
SITE_FORMS_WRITE_SECRET=

# Файл состояния (last update_id, маппинг топик ↔ siteId). Лежит в каталоге
# данных site-forms — попадает под тот же бэкап.
DELORESH_TG_BRIDGE_STATE=/var/lib/deloresh/site-forms/tg-bridge.json

# (Опционально) Альтернативный реестр объектов в виде JSON [{id, name}, …].
# Если не задан — берём из src/data/constructionSites.mock.ts (mock в коде).
SITES_REGISTRY_FILE=

# Скачивать ли фото/видео из Telegram-сообщений и заливать как фотофиксацию
# объекта в /api/sites/<siteId>/object-media. По умолчанию отключено
# (отчёты идут только текстом). Разрешите, когда вы готовы тратить место
# на диске под медиа.
TG_DOWNLOAD_MEDIA=

# Развёртывание без домена — только по IP.
#
# Что делает этот конфиг:
#   1. Раздаёт собранную SPA-статику React/Vite из /var/www/delores-object.
#   2. Все маршруты SPA уходят на index.html (try_files), чтобы React Router работал.
#   3. /api/* проксируется на бэкенд site-forms.mjs (Node.js, порт 8787 на 127.0.0.1).
#   4. Аплоад/скачивание медиа объектов поддерживается через client_max_body_size.
#
# Куда положить:
#   /etc/nginx/sites-available/delores-object-ip
# и включить:
#   sudo ln -s /etc/nginx/sites-available/delores-object-ip /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Важно: на одной машине сразу два варианта (порт 80 и порт 8080) ставить НЕ нужно —
# раскомментируйте только тот блок server{}, который вам подходит.

# ============================================================
#  Вариант A — основной сайт на порту 80 (адрес http://94.242.58.24/)
# ============================================================
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/delores-object;
    index index.html;

    # Аплоад фото/видео с объектов: до 100 МБ на запрос (синхронно с MAX_BODY_BYTES в site-forms.mjs).
    client_max_body_size 100m;

    # SPA — все неизвестные пути отдают index.html.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API заявок снабженцу, отчётов бригадира и медиа объектов.
    location /api/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Аплоад/скачивание медиа может занимать заметно дольше, чем JSON-запросы.
        proxy_connect_timeout 30s;
        proxy_send_timeout    300s;
        proxy_read_timeout    300s;
    }

    # Кэш статики Vite (имена файлов с хэшем — можно безопасно держать долго).
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|webmanifest)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
}

# ============================================================
#  Вариант B — отдельный порт 8080 (адрес http://94.242.58.24:8080/),
#  если 80-й порт занят чем-то другим. Раскомментируйте при необходимости
#  и закомментируйте Вариант A выше.
# ============================================================
